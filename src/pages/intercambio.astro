---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ContactForm from '../components/ContactForm.astro';
import siteData from '../content/site.yml';
import { url } from '../utils/url';

const { intercambio, contacto, ctas, escuela } = siteData;
const waUrl = `https://wa.me/${contacto.whatsapp}?text=${encodeURIComponent(ctas.intercambio.whatsapp_mensaje)}`;
---

<BaseLayout
  title={`${intercambio.titulo} | ${escuela.nombre}`}
  description={intercambio.descripcion}
  imageUrl={intercambio.imagen_hero}
>
  <!-- ── HERO ── -->
  <HeroSection
    titulo={intercambio.titulo}
    subtitulo={intercambio.subtitulo}
    imagen={intercambio.imagen_hero}
    ctaPrimario={{ texto: ctas.intercambio.texto, href: '#contacto-intercambio' }}
    ctaSecundario={{ texto: 'Consultar disponibilidad', href: waUrl }}
    badge="Programa estrella"
    overlay="dark"
  />

  <!-- ── URGENCIA ── -->
  <div class="bg-accent text-white py-4">
    <div class="container-base text-center">
      <p class="font-semibold text-sm md:text-base">
        ⚡ {intercambio.urgencia}
        <a href={url("#contacto-intercambio")} class="underline ml-2 hover:no-underline">
          Asegura tu lugar →
        </a>
      </p>
    </div>
  </div>

  <!-- ── DESCRIPCIÓN ── -->
  <section class="section-padding bg-white">
    <div class="container-base max-w-4xl">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-neutral-900 mb-6">
          {intercambio.descripcion}
        </h2>
        <p class="text-gray-600 text-lg leading-relaxed">
          {intercambio.descripcion_larga}
        </p>
      </div>
    </div>
  </section>

  <!-- ── DESTINOS ── -->
  <section class="section-padding bg-secondary">
    <div class="container-base">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
          Destinos disponibles
        </h2>
        <p class="text-gray-500">
          Dos destinos únicos. Una experiencia transformadora.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {intercambio.destinos.map((destino: any) => (
          <div class="bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="relative h-64 overflow-hidden">
              <img
                src={destino.imagen}
                alt={destino.ciudad}
                class="w-full h-full object-cover"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
              <div class="absolute bottom-4 left-4 text-white">
                <p class="font-heading font-bold text-2xl">{destino.ciudad}</p>
                <p class="text-white/80 text-sm">{destino.edad}</p>
              </div>
            </div>
            <div class="p-6">
              <p class="text-gray-600 text-sm leading-relaxed">{destino.descripcion}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── QUÉ INCLUYE ── -->
  <section class="section-padding bg-white">
    <div class="container-base">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-neutral-900 mb-8">
            Todo incluido — sin sorpresas
          </h2>
          <ul class="space-y-4">
            {intercambio.incluye.map((item: string) => (
              <li class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="text-gray-700 font-medium">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Puntos de venta -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {intercambio.puntos_venta.map((punto: any) => (
            <div class="bg-secondary rounded-2xl p-6">
              <span class="text-3xl mb-3 block" aria-hidden="true">{punto.icono}</span>
              <h3 class="font-heading font-bold text-lg text-primary mb-2">{punto.titulo}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{punto.descripcion}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── DOBLE CTA ── -->
  <section class="bg-primary text-white py-16">
    <div class="container-base text-center max-w-3xl">
      <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">
        {ctas.intercambio.texto}
      </h2>
      <p class="text-white/80 mb-8 text-lg">
        {intercambio.urgencia}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={url("#contacto-intercambio")} class="btn-secondary border-white text-white hover:bg-white hover:text-primary py-4 px-8 text-base">
          Apartar mi lugar
        </a>
        <a
          href={waUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-whatsapp py-4 px-8 text-base shadow-lg"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Quiero apartar mi lugar
        </a>
      </div>
    </div>
  </section>

  <!-- ── FORMULARIO ── -->
  <section id="contacto-intercambio" class="section-padding bg-secondary">
    <div class="container-base">
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-8">
          <h2 class="font-heading text-3xl font-bold text-neutral-900 mb-2">
            Aparta tu lugar — sin compromiso
          </h2>
          <p class="text-gray-500">{contacto.tiempo_respuesta}</p>
        </div>
        <ContactForm
          idiomaPredeterminado="Programa de Intercambio (París)"
          tituloForm=""
        />
      </div>
    </div>
  </section>
</BaseLayout>
