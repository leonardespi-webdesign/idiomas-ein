---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import CourseCard from '../components/CourseCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CtaBanner from '../components/CtaBanner.astro';
import siteData from '../content/site.yml';
import { url } from '../utils/url';

const {
  escuela,
  hero,
  propuestas_valor,
  idiomas,
  intercambio,
  testimonios,
  ctas,
  contacto,
} = siteData;

const waIntercambio = `https://wa.me/${contacto.whatsapp}?text=${encodeURIComponent(ctas.intercambio.whatsapp_mensaje)}`;
---

<BaseLayout>
  <!-- ── HERO ── -->
  <HeroSection
    titulo={hero.titulo}
    subtitulo={hero.subtitulo}
    imagen={hero.imagen}
    ctaPrimario={hero.cta_primario}
    ctaSecundario={hero.cta_secundario}
    overlay="medium"
  />

  <!-- ── PROPUESTAS DE VALOR ── -->
  <section class="section-padding bg-white">
    <div class="container-base">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
          ¿Por qué elegir nuestra escuela?
        </h2>
        <p class="text-gray-500 max-w-xl mx-auto">
          {escuela.slogan} — desde {escuela.fundacion}.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {propuestas_valor.map((item: any) => (
          <div class="flex flex-col items-center text-center p-6 rounded-2xl bg-secondary hover:shadow-md transition-shadow duration-300">
            <span class="text-4xl mb-4" aria-hidden="true">{item.icono}</span>
            <h3 class="font-heading font-bold text-lg text-primary mb-2">{item.titulo}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.descripcion}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── IDIOMAS ── -->
  <section class="section-padding bg-secondary">
    <div class="container-base">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
          Idiomas disponibles
        </h2>
        <p class="text-gray-500 max-w-xl mx-auto">
          Ofrecemos 8 idiomas con niveles A1 a C1, grupos pequeños y metodología comprobada.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {idiomas.map((idioma: any) => (
          <CourseCard
            nombre={idioma.nombre}
            slug={idioma.slug}
            descripcion={idioma.descripcion}
            imagen={idioma.imagen}
          />
        ))}
      </div>
      <div class="text-center mt-10">
        <a href={url("/cursos")} class="btn-primary text-base py-4 px-8">
          Ver todos los cursos
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── INTERCAMBIO (PRODUCTO ESTRELLA) ── -->
  <section class="section-padding bg-white overflow-hidden">
    <div class="container-base">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Image -->
        <div class="relative rounded-2xl overflow-hidden shadow-xl order-2 lg:order-1">
          <img
            src={intercambio.imagen_hero}
            alt={intercambio.titulo}
            class="w-full h-80 md:h-[480px] object-cover"
            loading="lazy"
          />
          <!-- Badge -->
          <div class="absolute top-4 left-4 bg-accent text-white text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full shadow">
            Producto estrella
          </div>
          <!-- Urgency badge -->
          <div class="absolute bottom-4 right-4 bg-white text-neutral-900 text-xs font-semibold px-4 py-2 rounded-full shadow-md">
            🔥 {intercambio.urgencia}
          </div>
        </div>

        <!-- Content -->
        <div class="order-1 lg:order-2">
          <span class="inline-block text-accent font-bold text-sm uppercase tracking-widest mb-3">
            Programa estrella
          </span>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-neutral-900 mb-4 leading-tight">
            {intercambio.titulo}
          </h2>
          <p class="text-gray-600 leading-relaxed mb-6 text-lg">
            {intercambio.descripcion_larga}
          </p>

          <!-- Destinations -->
          <div class="grid grid-cols-2 gap-4 mb-6">
            {intercambio.destinos.map((destino: any) => (
              <div class="bg-secondary rounded-xl p-4">
                <p class="font-heading font-bold text-primary text-sm">{destino.ciudad}</p>
                <p class="text-gray-500 text-xs mt-1">{destino.edad}</p>
              </div>
            ))}
          </div>

          <!-- Includes -->
          <ul class="space-y-2 mb-8">
            {intercambio.incluye.slice(0, 4).map((item: string) => (
              <li class="flex items-center gap-2 text-sm text-gray-700">
                <svg class="w-5 h-5 text-[#25D366] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                {item}
              </li>
            ))}
            <li class="text-sm text-gray-400 pl-7">+ {intercambio.incluye.length - 4} más incluidos</li>
          </ul>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4">
            <a href={url("/intercambio")} class="btn-primary py-4 px-6">
              Ver programa completo
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </a>
            <a
              href={waIntercambio}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-whatsapp py-4 px-6"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Preguntar sobre el intercambio
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── TESTIMONIOS ── -->
  <section class="section-padding bg-secondary">
    <div class="container-base">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
          Lo que dicen nuestras familias
        </h2>
        <p class="text-gray-500 max-w-xl mx-auto">
          Más de {escuela.fundacion ? new Date().getFullYear() - escuela.fundacion : 'décadas de'} años de resultados reales hablan por nosotros.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonios.slice(0, 3).map((t: any) => (
          <TestimonialCard
            nombre={t.nombre}
            rol={t.rol}
            texto={t.texto}
            imagen={t.imagen}
          />
        ))}
      </div>
      <div class="text-center mt-10">
        <a href={url("/testimonios")} class="btn-secondary text-sm py-3 px-6">
          Ver todos los testimonios
        </a>
      </div>
    </div>
  </section>

  <!-- ── CTA FINAL ── -->
  <CtaBanner
    titulo={ctas.inscripcion.texto}
    subtitulo="Grupos pequeños, metodología comprobada y casi 100 años de trayectoria."
    ctaTexto="Reserva tu lugar"
    ctaHref={url("/cursos")}
    whatsappMensaje={ctas.inscripcion.whatsapp_mensaje}
  />
</BaseLayout>
