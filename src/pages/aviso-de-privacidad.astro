---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteData from '../content/site.yml';

const { aviso_privacidad, escuela, contacto } = siteData;
---

<BaseLayout
  title={`${aviso_privacidad.titulo} | ${escuela.nombre}`}
  description="Aviso de privacidad conforme a la Ley Federal de Protección de Datos Personales en Posesión de los Particulares (LFPDPPP)."
>
  <!-- ── HEADER ── -->
  <section class="bg-primary text-white py-12 md:py-16">
    <div class="container-base max-w-3xl">
      <h1 class="font-heading text-3xl md:text-4xl font-bold mb-2">
        {aviso_privacidad.titulo}
      </h1>
      <p class="text-blue-200 text-sm">
        Última actualización: {aviso_privacidad.fecha_actualizacion}
      </p>
    </div>
  </section>

  <!-- ── CONTENT ── -->
  <section class="section-padding bg-white">
    <div class="container-base max-w-3xl">
      <div class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:text-neutral-900 prose-p:text-gray-700 prose-p:leading-relaxed">

        <p>{aviso_privacidad.intro}</p>

        <h2>{aviso_privacidad.responsable_titulo}</h2>
        <!-- TODO: reemplazar nombre oficial -->
        <p>{aviso_privacidad.responsable_texto}</p>
        <ul>
          <li><strong>Correo:</strong> <a href={`mailto:${contacto.email_principal}`}>{contacto.email_principal}</a></li>
          <li><strong>WhatsApp:</strong> {contacto.whatsapp_display}</li>
          <li><strong>Ciudad:</strong> {contacto.direccion}</li>
        </ul>

        <h2>{aviso_privacidad.datos_titulo}</h2>
        <ul>
          {aviso_privacidad.datos_items.map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>

        <h2>{aviso_privacidad.finalidades_titulo}</h2>
        <p><strong>Finalidades primarias (necesarias para la relación):</strong></p>
        <ul>
          {aviso_privacidad.finalidades_primarias.map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
        <p><strong>Finalidades secundarias (puede oponerse a ellas):</strong></p>
        <ul>
          {aviso_privacidad.finalidades_secundarias.map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>

        <h2>{aviso_privacidad.transferencias_titulo}</h2>
        <p>{aviso_privacidad.transferencias_texto}</p>

        <h2>{aviso_privacidad.derechos_titulo}</h2>
        <p>{aviso_privacidad.derechos_texto}</p>
        <ul>
          <li><strong>Correo:</strong> <a href={`mailto:${contacto.email_principal}`}>{contacto.email_principal}</a></li>
        </ul>

        <h2>{aviso_privacidad.cambios_titulo}</h2>
        <p>{aviso_privacidad.cambios_texto}</p>

      </div>

      <div class="mt-10 pt-8 border-t border-gray-200">
        <a href={url("/")} class="text-primary font-semibold hover:text-accent transition-colors flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Volver al inicio
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
