---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import siteData from '../content/site.yml';

const { nosotros, escuela, ctas } = siteData;
---

<BaseLayout
  title={`Nosotros | ${escuela.nombre}`}
  description={nosotros.descripcion}
  imageUrl={nosotros.imagen}
>
  <!-- ── HEADER ── -->
  <section class="bg-primary text-white py-16 md:py-24">
    <div class="container-base max-w-3xl text-center">
      <span class="inline-block bg-accent text-white text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6">Nuestra historia</span>
      <h1 class="font-heading text-4xl md:text-5xl font-bold leading-tight mb-4">
        {nosotros.titulo}
      </h1>
      <p class="text-blue-100 text-lg">{nosotros.subtitulo}</p>
    </div>
  </section>

  <!-- ── HISTORIA ── -->
  <section class="section-padding bg-white">
    <div class="container-base">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-gray-700 text-lg leading-relaxed mb-6">
            {nosotros.descripcion}
          </p>
          <p class="text-gray-700 text-lg leading-relaxed mb-8">
            {nosotros.descripcion_2}
          </p>

          <!-- Stats -->
          <div class="grid grid-cols-2 gap-4">
            {nosotros.logros.map((logro: string) => (
              <div class="flex items-start gap-3 bg-secondary rounded-xl p-4">
                <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-sm text-gray-700 font-medium">{logro}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="rounded-2xl overflow-hidden shadow-xl">
          <img
            src={nosotros.imagen}
            alt={`${escuela.nombre} — instalaciones`}
            class="w-full h-80 md:h-[480px] object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ── MISIÓN Y VISIÓN ── -->
  <section class="section-padding bg-secondary">
    <div class="container-base">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h2 class="font-heading font-bold text-xl text-primary mb-3">Misión</h2>
          <p class="text-gray-600 leading-relaxed">{nosotros.mision}</p>
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
          </div>
          <h2 class="font-heading font-bold text-xl text-primary mb-3">Visión</h2>
          <p class="text-gray-600 leading-relaxed">{nosotros.vision}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── VALORES ── -->
  <section class="section-padding bg-white">
    <div class="container-base max-w-3xl text-center">
      <h2 class="font-heading text-3xl font-bold text-neutral-900 mb-10">
        Nuestros valores
      </h2>
      <div class="flex flex-wrap justify-center gap-4">
        {nosotros.valores.map((valor: string) => (
          <span class="bg-primary text-white px-6 py-3 rounded-full font-semibold text-sm">
            {valor}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ── ACREDITACIONES ── -->
  <section class="section-padding bg-secondary">
    <div class="container-base">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
          Acreditaciones y afiliaciones
        </h2>
        <p class="text-gray-500 max-w-xl mx-auto">
          Respaldados por las instituciones educativas más reconocidas del mundo.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {nosotros.acreditaciones.map((ac: any) => (
          <div class="bg-white rounded-2xl p-6 shadow-sm text-center hover:shadow-md transition-shadow">
            <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
              </svg>
            </div>
            <h3 class="font-heading font-bold text-primary mb-2">{ac.nombre}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{ac.descripcion}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <CtaBanner
    titulo={ctas.inscripcion.texto}
    subtitulo="Únete a casi 100 años de historia educativa."
    ctaTexto="Conoce nuestros cursos"
    ctaHref={url("/cursos")}
    whatsappMensaje={ctas.inscripcion.whatsapp_mensaje}
  />
</BaseLayout>
