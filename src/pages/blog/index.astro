---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import siteData from '../../content/site.yml';

const { escuela } = siteData;

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title={`Blog | ${escuela.nombre}`}
  description="Consejos de aprendizaje de idiomas, noticias del mundo de la educación bilingüe y experiencias de intercambio estudiantil."
>
  <!-- ── HEADER ── -->
  <section class="bg-primary text-white py-16 md:py-24">
    <div class="container-base max-w-3xl text-center">
      <h1 class="font-heading text-4xl md:text-5xl font-bold mb-4">
        Blog
      </h1>
      <p class="text-blue-100 text-lg">
        Recursos, consejos y experiencias del mundo de los idiomas.
      </p>
    </div>
  </section>

  <!-- ── POSTS GRID ── -->
  <section class="section-padding bg-secondary">
    <div class="container-base">
      {posts.length === 0 ? (
        <p class="text-center text-gray-500 py-16">
          Próximamente nuevos artículos.
        </p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map(post => (
            <BlogCard
              slug={post.slug}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              imageUrl={post.data.imageUrl}
              imageAlt={post.data.imageAlt}
              tags={post.data.tags}
              author={post.data.author}
            />
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
