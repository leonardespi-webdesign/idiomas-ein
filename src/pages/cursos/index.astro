---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CourseCard from '../../components/CourseCard.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import siteData from '../../content/site.yml';

const { idiomas, niveles, orientaciones, formato_curso, escuela, ctas, contacto } = siteData;
const waUrl = `https://wa.me/${contacto.whatsapp}?text=${encodeURIComponent(ctas.inscripcion.whatsapp_mensaje)}`;
---

<BaseLayout
  title={`Cursos de idiomas | ${escuela.nombre}`}
  description="Cursos de inglés, francés, alemán, italiano, mandarín, japonés, coreano y ruso. Grupos pequeños, niveles A1-C1, modalidad presencial en CDMX."
>
  <!-- ── PAGE HEADER ── -->
  <section class="bg-primary text-white py-16 md:py-24">
    <div class="container-base text-center max-w-3xl">
      <h1 class="font-heading text-4xl md:text-5xl font-bold mb-4 leading-tight">
        Cursos de idiomas
      </h1>
      <p class="text-blue-100 text-lg leading-relaxed">
        {idiomas.length} idiomas disponibles. Grupos de máximo {formato_curso.max_alumnos} alumnos.
        {formato_curso.horas_semana} horas por semana durante {formato_curso.duracion_ciclo}.
      </p>
    </div>
  </section>

  <!-- ── IDIOMAS GRID ── -->
  <section class="section-padding bg-white">
    <div class="container-base">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
          Elige tu idioma
        </h2>
        <p class="text-gray-500 max-w-xl mx-auto">
          Todos los cursos son presenciales en {escuela.ciudad}. Selecciona el idioma para ver niveles y orientaciones.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {idiomas.map((idioma: any) => (
          <CourseCard
            nombre={idioma.nombre}
            slug={idioma.slug}
            descripcion={idioma.descripcion}
            imagen={idioma.imagen}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ── NIVELES ── -->
  <section class="section-padding bg-secondary">
    <div class="container-base">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-neutral-900 mb-6">
            Niveles disponibles
          </h2>
          <p class="text-gray-600 mb-8 leading-relaxed">
            Evaluamos tu nivel al inicio para ubicarte en el grupo correcto. No importa si eres principiante absoluto o tienes conocimientos previos.
          </p>
          <div class="space-y-3">
            {niveles.map((nivel: any) => (
              <div class="flex items-center gap-4 bg-white rounded-xl px-5 py-4 shadow-sm">
                <span class="font-bold text-primary bg-primary/10 rounded-lg px-3 py-1.5 text-sm min-w-[3.5rem] text-center">
                  {nivel.codigo}
                </span>
                <span class="text-neutral-900 font-medium">{nivel.nombre}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Orientaciones -->
        <div>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-neutral-900 mb-6">
            Orientaciones
          </h2>
          <p class="text-gray-600 mb-8 leading-relaxed">
            Personaliza tu aprendizaje según tus objetivos.
          </p>
          <div class="space-y-4">
            {orientaciones.map((o: any) => (
              <div class="bg-white rounded-2xl p-5 shadow-sm flex items-start gap-4">
                <span class="text-2xl flex-shrink-0">{o.icono}</span>
                <div>
                  <h3 class="font-heading font-semibold text-primary mb-1">{o.titulo}</h3>
                  <p class="text-gray-600 text-sm">{o.descripcion}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FORMATO ── -->
  <section class="section-padding bg-white">
    <div class="container-base max-w-4xl">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
          Formato del curso
        </h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center bg-secondary rounded-2xl p-6">
          <p class="font-heading font-bold text-3xl text-primary mb-1">{formato_curso.horas_semana}h</p>
          <p class="text-gray-600 text-sm">por semana</p>
        </div>
        <div class="text-center bg-secondary rounded-2xl p-6">
          <p class="font-heading font-bold text-3xl text-primary mb-1">{formato_curso.duracion_ciclo}</p>
          <p class="text-gray-600 text-sm">por ciclo</p>
        </div>
        <div class="text-center bg-secondary rounded-2xl p-6">
          <p class="font-heading font-bold text-3xl text-primary mb-1">≤{formato_curso.max_alumnos}</p>
          <p class="text-gray-600 text-sm">alumnos por grupo</p>
        </div>
        <div class="text-center bg-secondary rounded-2xl p-6">
          <p class="font-heading font-bold text-lg text-primary mb-1 mt-1">{formato_curso.modalidad}</p>
          <p class="text-gray-600 text-sm">modalidad</p>
        </div>
      </div>
      <div class="text-center mt-8">
        <p class="text-gray-500 text-sm mb-6">{formato_curso.horarios}</p>
        <a href={waUrl} target="_blank" rel="noopener noreferrer" class="btn-whatsapp py-4 px-8">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Consultar disponibilidad de grupos
        </a>
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <CtaBanner
    titulo={ctas.inscripcion.texto}
    subtitulo={ctas.inscripcion.subtitulo}
    ctaTexto="Habla con un asesor"
    ctaHref={url("/contacto")}
    whatsappMensaje={ctas.inscripcion.whatsapp_mensaje}
  />
</BaseLayout>
