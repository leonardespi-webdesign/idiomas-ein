---
import siteData from '../content/site.yml';
import { url } from '../utils/url';

const { escuela, contacto, redes_sociales, nav } = siteData;
const currentYear = new Date().getFullYear();

const waUrl = `https://wa.me/${contacto.whatsapp}?text=${encodeURIComponent(siteData.ctas.inscripcion.whatsapp_mensaje)}`;

// Split nav links into two columns
const half = Math.ceil(nav.links.length / 2);
const linksLeft  = nav.links.slice(0, half);
const linksRight = nav.links.slice(half);
---

<footer class="bg-primary text-white">
  <div class="container-base py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-16">

      <!-- ── Col 1: Brand ── -->
      <div class="flex flex-col gap-5">
        <a href={url('/')} class="flex items-center gap-3">
          <div class="w-10 h-10 bg-white rounded-md flex items-center justify-center flex-shrink-0">
            <img src={url('/favicon.svg')} alt="Logo" class="w-9 h-9" />
          </div>
          <div>
            <!-- TODO: reemplazar con nombre oficial -->
            <span class="font-heading font-bold text-base leading-tight block">{escuela.nombre}</span>
            <span class="text-blue-300 text-xs">{escuela.slogan}</span>
          </div>
        </a>

        <!-- Partner/accreditation icons -->
        <div class="flex items-center gap-3 flex-wrap">
          {['img1','img2','img3','img4','img5','img6'].map((name) => (
            <div class="w-8 h-8 flex items-center justify-center flex-shrink-0">
              <img src={url(`/icons/${name}.png`)} alt="" class="w-full h-full object-contain brightness-0 invert" loading="lazy" />
            </div>
          ))}
        </div>

        <p class="text-blue-200 text-sm leading-relaxed">
          Desde {escuela.fundacion} formando bilingües en {escuela.ciudad} con estándares Cambridge y Oxford.
        </p>

        <!-- Social -->
        <div class="flex items-center gap-3">
          <a href={redes_sociales.facebook} target="_blank" rel="noopener noreferrer"
             class="w-8 h-8 rounded-lg bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors"
             aria-label="Facebook">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href={redes_sociales.instagram} target="_blank" rel="noopener noreferrer"
             class="w-8 h-8 rounded-lg bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors"
             aria-label="Instagram">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- ── Col 2: Navigation (2 sub-columns) ── -->
      <div>
        <h3 class="font-heading font-semibold text-xs uppercase tracking-widest text-blue-300 mb-5">
          Navegación
        </h3>
        <div class="grid grid-cols-2 gap-x-4 gap-y-2.5">
          {[...linksLeft, { label: 'Aviso de privacidad', href: '/aviso-de-privacidad' }].map((link: any) => (
            <a href={url(link.href)} class="text-blue-100 hover:text-white text-sm transition-colors truncate">
              {link.label}
            </a>
          ))}
          {linksRight.map((link: any) => (
            <a href={url(link.href)} class="text-blue-100 hover:text-white text-sm transition-colors truncate">
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <!-- ── Col 3: Contact ── -->
      <div class="flex flex-col gap-5">
        <h3 class="font-heading font-semibold text-xs uppercase tracking-widest text-blue-300">
          Contacto
        </h3>

        <ul class="space-y-3 text-sm text-blue-100">
          <li>
            <a href={`https://wa.me/${contacto.whatsapp}`} target="_blank" rel="noopener noreferrer"
               class="flex items-center gap-2.5 hover:text-white transition-colors group">
              <svg class="w-4 h-4 text-[#25D366] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              {contacto.whatsapp_display}
            </a>
          </li>
          <li>
            <a href={`mailto:${contacto.email_principal}`}
               class="flex items-center gap-2.5 hover:text-white transition-colors">
              <svg class="w-4 h-4 flex-shrink-0 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <span class="break-all">{contacto.email_principal}</span>
            </a>
          </li>
          <li class="flex items-center gap-2.5">
            <svg class="w-4 h-4 flex-shrink-0 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <a href={contacto.maps_url} target="_blank" rel="noopener noreferrer"
               class="hover:text-white transition-colors">
              {escuela.ciudad}
            </a>
          </li>
        </ul>

      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="container-base py-5">

      <!-- Mobile: three stacked left-aligned lines -->
      <div class="flex flex-col items-start gap-3 sm:hidden">
        <span class="text-xs text-blue-300 leading-snug">
          © {currentYear} {escuela.nombre}.<br/>Todos los derechos reservados.
        </span>
        <a href={url('/aviso-de-privacidad')} class="text-xs text-blue-300 hover:text-white transition-colors">
          Aviso de privacidad
        </a>
        <a href="https://www.leonardespi.me/web/" target="_blank" rel="noopener noreferrer"
           class="text-xs text-blue-400/60 hover:text-white transition-colors">
          Diseño por leonardespi
        </a>
      </div>

      <!-- Desktop: copyright left | links right -->
      <div class="hidden sm:flex justify-between items-center gap-4 text-xs text-blue-300">
        <span>© {currentYear} {escuela.nombre}. Todos los derechos reservados.</span>
        <div class="flex items-center gap-4 shrink-0">
          <a href={url('/aviso-de-privacidad')} class="hover:text-white transition-colors">
            Aviso de privacidad
          </a>
          <span class="text-white/20">·</span>
          <a href="https://www.leonardespi.me/web/" target="_blank" rel="noopener noreferrer"
             class="text-blue-400/60 hover:text-white transition-colors">
            Diseño por leonardespi
          </a>
        </div>
      </div>

    </div>
  </div>
</footer>
