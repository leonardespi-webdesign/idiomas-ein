---
interface Props {
  nombre: string;
  rol: string;
  texto: string;
  imagen: string;
}

const { nombre, rol, texto, imagen } = Astro.props;
---

<div class="bg-white rounded-2xl shadow-md p-6 md:p-8 flex flex-col gap-4 border border-gray-100 hover:shadow-lg transition-shadow duration-300">
  <!-- Quote icon -->
  <svg class="w-10 h-10 text-accent/30 flex-shrink-0" fill="currentColor" viewBox="0 0 32 32">
    <path d="M9.352 4C4.456 7.456 1 13.12 1 19.36c0 5.088 3.072 8.064 6.624 8.064 3.36 0 5.856-2.688 5.856-5.856 0-3.168-2.208-5.472-5.088-5.472-.576 0-1.344.096-1.536.192.48-3.264 3.552-7.104 6.624-9.024L9.352 4zm16.512 0c-4.8 3.456-8.256 9.12-8.256 15.36 0 5.088 3.072 8.064 6.624 8.064 3.264 0 5.856-2.688 5.856-5.856 0-3.168-2.304-5.472-5.184-5.472-.576 0-1.248.096-1.44.192.48-3.264 3.456-7.104 6.528-9.024L25.864 4z"/>
  </svg>

  <!-- Text -->
  <p class="text-gray-700 leading-relaxed italic flex-1">
    "{texto}"
  </p>

  <!-- Author -->
  <div class="flex items-center gap-3 pt-2 border-t border-gray-100">
    <img
      src={imagen}
      alt={nombre}
      class="w-12 h-12 rounded-full object-cover flex-shrink-0"
      loading="lazy"
    />
    <div>
      <p class="font-semibold text-neutral-900 text-sm">{nombre}</p>
      <p class="text-gray-500 text-xs">{rol}</p>
    </div>
  </div>
</div>
