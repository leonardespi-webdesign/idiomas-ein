---
interface Props {
  nombre: string;
  slug: string;
  descripcion: string;
  imagen: string;
}

const { nombre, slug, descripcion, imagen } = Astro.props;
---

<a
  href={`/cursos/${slug}`}
  class="group relative flex flex-col overflow-hidden rounded-xl shadow-md hover:shadow-xl transition-all duration-300 bg-white border border-gray-100"
  aria-label={nombre}
>
  <!-- Image -->
  <div class="relative h-48 overflow-hidden">
    <img
      src={imagen}
      alt={nombre}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
  </div>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-5">
    <h3 class="font-heading font-bold text-xl text-primary mb-2 group-hover:text-accent transition-colors">
      {nombre}
    </h3>
    <p class="text-gray-600 text-sm leading-relaxed flex-1 mb-4">
      {descripcion}
    </p>
    <span class="text-primary text-sm font-semibold flex items-center gap-1 group-hover:gap-2 transition-all">
      Ver curso
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
      </svg>
    </span>
  </div>
</a>
