---
import siteData from '../content/site.yml';
import { url } from '../utils/url';

const { escuela, nav, contacto, ctas } = siteData;
const waUrl = `https://wa.me/${contacto.whatsapp}?text=${encodeURIComponent(ctas.inscripcion.whatsapp_mensaje)}`;

// Strip base prefix for active-link comparison against site.yml hrefs (e.g. "/cursos")
const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // "/IEIN" or ""
const currentPath = Astro.url.pathname.replace(base, '') || '/';
---

<header>
  <!-- Topbar -->
  <div class="bg-primary text-white text-xs py-2 hidden md:block">
    <div class="container-base flex justify-between items-center">
      <span>
        📧 <a href={`mailto:${contacto.email_principal}`} class="hover:text-yellow-200 transition-colors">{contacto.email_principal}</a>
      </span>
      <span>{contacto.tiempo_respuesta}</span>
    </div>
  </div>

  <!-- Main nav -->
  <nav class="bg-primary text-white sticky top-0 z-50 shadow-lg">
    <div class="container-base">
      <div class="flex items-center justify-between h-16">

        <!-- Logo / School name -->
        <a href={url('/')} class="flex items-center gap-3 group" aria-label="Inicio">
          <div class="w-9 h-9 bg-white rounded-md flex items-center justify-center flex-shrink-0">
            <img src={url('/favicon.svg')} alt="Logo" class="w-8 h-8" />
          </div>
          <div class="hidden sm:block">
            <span class="font-heading font-bold text-base leading-none block">
              {/* TODO: reemplazar con nombre oficial */}
              {escuela.nombre}
            </span>
            <span class="text-blue-200 text-xs">desde {escuela.fundacion}</span>
          </div>
        </a>

        <!-- Desktop nav links -->
        <div class="hidden lg:flex items-center gap-1">
          {nav.links.map((link: any) => (
            <a
              href={url(link.href)}
              class={`px-3 py-2 rounded text-sm font-medium transition-colors duration-150
                ${currentPath === link.href
                  ? 'bg-white/20 text-white'
                  : 'hover:bg-white/10 text-blue-100 hover:text-white'}
                ${link.href === '/intercambio' ? 'text-yellow-300 hover:text-yellow-200' : ''}`}
            >
              {link.label}
            </a>
          ))}
        </div>

        <!-- Desktop CTA -->
        <div class="hidden lg:flex items-center gap-3">
          <a
            href={waUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-whatsapp text-sm py-2 px-4 rounded-lg"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            {contacto.whatsapp_display}
          </a>
        </div>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 rounded-md hover:bg-white/10 transition-colors"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden lg:hidden border-t border-white/20 pb-4 pt-2">
        {nav.links.map((link: any) => (
          <a
            href={url(link.href)}
            class={`block px-2 py-3 text-sm font-medium border-b border-white/10 last:border-0
              ${link.href === '/intercambio' ? 'text-yellow-300' : 'text-blue-100 hover:text-white'}`}
          >
            {link.label}
          </a>
        ))}
        <div class="pt-4">
          <a
            href={waUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-whatsapp w-full justify-center text-sm py-3"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp: {contacto.whatsapp_display}
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isExpanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!isExpanded));
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });

  // Close menu on nav link click (mobile)
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
