---
import siteData from '../content/site.yml';
import { url } from '../utils/url';

interface Props {
  idiomaPredeterminado?: string;
  tituloForm?: string;
  compact?: boolean;
}

const { idiomaPredeterminado = '', tituloForm, compact = false } = Astro.props;
const { formulario, contacto } = siteData;
---

<div class={compact ? '' : 'bg-white rounded-2xl shadow-lg p-6 md:p-10 border border-gray-100'}>
  {tituloForm && (
    <h2 class="font-heading text-2xl md:text-3xl font-bold text-neutral-900 mb-2">
      {tituloForm}
    </h2>
  )}
  {tituloForm && (
    <p class="text-gray-500 text-sm mb-6">{contacto.tiempo_respuesta}</p>
  )}

  <form
    action={formulario.formspree_url}
    method="POST"
    class="space-y-5"
    novalidate
    id="contact-form"
  >
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <!-- Name -->
      <div>
        <label for="nombre" class="block text-sm font-semibold text-neutral-900 mb-1.5">
          {formulario.nombre_label} <span class="text-accent">*</span>
        </label>
        <input
          type="text"
          id="nombre"
          name="nombre"
          required
          placeholder={formulario.placeholder_nombre}
          class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors placeholder:text-gray-400"
        />
      </div>

      <!-- Email -->
      <div>
        <label for="email" class="block text-sm font-semibold text-neutral-900 mb-1.5">
          {formulario.email_label} <span class="text-accent">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder={formulario.placeholder_email}
          class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors placeholder:text-gray-400"
        />
      </div>
    </div>

    <!-- Phone -->
    <div>
      <label for="telefono" class="block text-sm font-semibold text-neutral-900 mb-1.5">
        {formulario.telefono_label}
      </label>
      <input
        type="tel"
        id="telefono"
        name="telefono"
        placeholder={formulario.placeholder_telefono}
        class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors placeholder:text-gray-400"
      />
    </div>

    <!-- Language interest -->
    <div>
      <label for="idioma" class="block text-sm font-semibold text-neutral-900 mb-1.5">
        {formulario.idioma_label} <span class="text-accent">*</span>
      </label>
      <select
        id="idioma"
        name="idioma"
        required
        class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-white text-gray-700"
      >
        <option value="" disabled selected={!idiomaPredeterminado}>
          {formulario.idioma_placeholder}
        </option>
        {formulario.idioma_opciones.map((opcion: string) => (
          <option value={opcion} selected={opcion === idiomaPredeterminado}>
            {opcion}
          </option>
        ))}
      </select>
    </div>

    <!-- Message -->
    <div>
      <label for="mensaje" class="block text-sm font-semibold text-neutral-900 mb-1.5">
        {formulario.mensaje_label}
      </label>
      <textarea
        id="mensaje"
        name="mensaje"
        rows="4"
        placeholder={formulario.placeholder_mensaje}
        class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors resize-none placeholder:text-gray-400"
      ></textarea>
    </div>

    <!-- Privacy notice -->
    <p class="text-xs text-gray-400">
      {formulario.nota_privacidad}{' '}
      <a href={url("/aviso-de-privacidad" )} class="text-primary hover:text-accent underline">
        {formulario.link_privacidad}
      </a>.
    </p>

    <!-- Submit -->
    <button
      type="submit"
      class="btn-primary w-full justify-center text-base py-4"
    >
      {formulario.enviar_texto}
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
      </svg>
    </button>
  </form>
</div>
