---
interface Props {
  titulo: string;
  subtitulo: string;
  imagen: string;
  ctaPrimario: { texto: string; href: string };
  ctaSecundario?: { texto: string; href: string };
  badge?: string;
  overlay?: 'light' | 'medium' | 'dark';
}

const {
  titulo,
  subtitulo,
  imagen,
  ctaPrimario,
  ctaSecundario,
  badge,
  overlay = 'medium',
} = Astro.props;

const overlayClass = {
  light: 'from-black/40 to-black/20',
  medium: 'from-black/70 via-black/50 to-black/20',
  dark: 'from-black/85 via-black/60 to-black/30',
}[overlay];
---

<section class="relative min-h-[85vh] md:min-h-[90vh] flex items-center overflow-hidden">
  <!-- Background image -->
  <img
    src={imagen}
    alt=""
    role="presentation"
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
  />

  <!-- Overlay gradient -->
  <div class={`absolute inset-0 bg-gradient-to-r ${overlayClass}`}></div>

  <!-- Content -->
  <div class="relative container-base py-20 md:py-32">
    <div class="max-w-2xl">
      {badge && (
        <span class="inline-block bg-accent text-white text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6">
          {badge}
        </span>
      )}

      <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        {titulo}
      </h1>

      <p class="text-lg md:text-xl text-white/90 leading-relaxed mb-8 max-w-xl">
        {subtitulo}
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href={ctaPrimario.href} class="btn-primary text-base py-4 px-8 shadow-lg hover:shadow-xl">
          {ctaPrimario.texto}
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
        {ctaSecundario && (
          <a href={ctaSecundario.href} class="btn-secondary text-base py-4 px-8 shadow-lg border-white text-white hover:bg-white hover:text-primary">
            {ctaSecundario.texto}
          </a>
        )}
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden md:block">
    <div class="w-6 h-10 border-2 border-white/50 rounded-full flex justify-center pt-2">
      <div class="w-1 h-2 bg-white/70 rounded-full animate-bounce"></div>
    </div>
  </div>
</section>
